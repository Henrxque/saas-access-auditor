# URL de conexão principal do banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/saas_access_auditor"

# URL de conexão shadow para migrações (opcional)
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/saas_access_auditor_shadow"

# Chave secreta para autenticação e sessões
AUTH_SECRET="replace-with-a-secure-random-string"

# URL base da aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"
